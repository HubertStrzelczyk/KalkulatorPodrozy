<LinearLayout xmlns:android="http://schemas.android.com/apk/res/xml/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="20dp">

    <EditText android:id="@+id/poleDystans" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Dystans (km)" android:inputType="numberDecimal" />
    <EditText android:id="@+id/poleSpalanie" android:layout_width="match_parent" android:layout_height="wrap_content" android:hint="Spalanie (l/100km)" android:inputType="numberDecimal" android:layout_marginTop="10dp" />
    <Spinner android:id="@+id/wyborPaliwa" android:layout_width="match_parent" android:layout_height="wrap_content" android:layout_marginVertical="15dp" android:entries="@array/typy_paliwa" />
    <Button android:id="@+id/przyciskDalej" android:layout_width="match_parent" android:layout_height="wrap_content" android:text="Podsumowanie" />
    <TextView android:id="@+id/tekstStatusu" android:layout_width="wrap_content" android:layout_height="wrap_content" android:layout_marginTop="20dp" android:text="Status: Oczekiwanie" />
</LinearLayout>